{
    "name": "jiuwufen/jiuwufen-sdk",
    "description": "95分开放平台官方 PHP SDK",
    "type": "library",
    "keywords": [
        "95fen",
        "jiuwufen",
        "sdk",
        "api"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "95分开放平台团队",
            "email": "support@95fenapp.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "JiuWuFen\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JiuWuFen\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 src/",
        "cs-fix": "phpcbf --standard=PSR12 src/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}